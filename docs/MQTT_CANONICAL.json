{
  "version": 2,
  "description": "Canonical MQTT discovery unique_ids for inverter-bridge daemon. Suffix convention: `_l1`/`_l2` for AC split-phase (load/grid), `_mppt1`/`_mppt2` for PV strings. The earlier `_1`/`_2` scheme was retired 2026-05-20 because it was ambiguous (meant phase for AC and string for PV).",
  "aggregates": [
    "total_battery_state_of_charge",
    "total_battery_voltage",
    "total_battery_power",
    "total_bus_voltage",
    "total_load_power",
    "total_pv_power",
    "total_grid_power",
    "total_grid_voltage",
    "total_grid_frequency",
    "total_mode",
    "total_capacity",
    "total_battery_energy_in",
    "total_battery_energy_out",
    "total_pv_energy",
    "total_load_energy",
    "total_grid_energy_in",
    "total_grid_energy_out"
  ],
  "per_inverter_suffixes": [
    "battery_current",
    "battery_voltage",
    "bus_voltage",
    "load_power",
    "load_power_l1",
    "load_power_l2",
    "load_apparent_power",
    "load_percentage",
    "ac_output_voltage",
    "ac_output_frequency",
    "grid_voltage",
    "grid_power",
    "grid_frequency",
    "temperature",
    "temperature_dc_dc",
    "temperature_dc_ac",
    "temperature_transformer",
    "pv_voltage_mppt1",
    "pv_voltage_mppt2",
    "pv_current",
    "pv_current_mppt1",
    "pv_current_mppt2",
    "pv_power",
    "pv_power_mppt1",
    "pv_power_mppt2",
    "device_mode",
    "charge_state"
  ],
  "meta": [
    "meta_poll_duration_ms",
    "meta_crc_fails_total",
    "meta_uptime_s"
  ],
  "binary_sensors": [
    "inverter_bridge_online"
  ]
}
